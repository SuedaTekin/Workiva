{% extends 'base.html.twig' %}

{% block title %}Edit Project{% endblock %}

{% block body %}

<div class="container-fluid p-4">

<div class="d-flex justify-content-between align-items-center mb-4">
<h2 class="fw-bold m-0">Edit Project</h2>

<a href="{{ path('app_project_list') }}" class="btn btn-light border">
<i class="fas fa-arrow-left"></i> Back
</a>

</div>

<div class="card border-0 shadow-sm">

<div class="card-body p-4">

{{ form_start(form) }}

<div class="row">

<div class="col-md-6 mb-3">
<label class="form-label fw-semibold">Project Name</label>
{{ form_widget(form.name, {'attr': {'class': 'form-control'}}) }}
</div>

<div class="col-md-6 mb-3">
<label class="form-label fw-semibold">Responsible</label>
{{ form_widget(form.responsible, {'attr': {'class': 'form-control'}}) }}
</div>

<div class="col-md-6 mb-3">
<label class="form-label fw-semibold">Progress (%)</label>
{{ form_widget(form.progress, {'attr': {'class': 'form-control'}}) }}
</div>

<div class="col-md-6 mb-3">
<label class="form-label fw-semibold">Status</label>
{{ form_widget(form.status, {'attr': {'class': 'form-control'}}) }}
</div>

<div class="col-md-12 mb-3">
<label class="form-label fw-semibold">Description</label>
{{ form_widget(form.description, {'attr': {'class': 'form-control'}}) }}
</div>

</div>

<div class="mt-3">

<button class="btn btn-primary px-4">
<i class="fas fa-save"></i> Update Project
</button>

<a href="{{ path('app_project_list') }}"
class="btn btn-light border ms-2">
Cancel
</a>

</div>

{{ form_end(form) }}

</div>

</div>

</div>

{% endblock %}