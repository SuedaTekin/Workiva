{% extends 'base.html.twig' %}

{% block title %}Projects Management{% endblock %}

{% block body %}
<div class="container-fluid p-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold m-0">Project List</h2>
        <a href="{{ path('app_project_new') }}" class="btn btn-primary">
            <i class="bi bi-person-plus-fill"></i> Add New Project
        </a>
    </div>

    <!--<div class="row mb-4">
        <div class="col-md-3">
            <div class="card border-0 shadow-sm bg-primary text-white p-3">
                <small>Total Projects</small>
                <h4 class="m-0">12</h4>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm bg-success text-white p-3">
                <small>Completed</small>
                <h4 class="m-0">8</h4>
            </div>
        </div>
    </div> -->

    <div class="card border-0 shadow-sm">
        <div class="card-header bg-white py-3">
            <h5 class="card-title mb-0 text-secondary">Active Projects</h5>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th class="ps-4">Project Name</th>
                            <th>Responsible</th>
                            <th>Progress</th>
                            <th>Status</th>
                            <th class="text-end pe-4">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        {# Şimdilik örnek veri, ileride 'for project in projects' döngüsü gelecek #}
                        <tbody>

                        {% for project in projects %}
                            <tr>

                                <td class="ps-4 fw-bold">
                                    {{ project.name }}
                                </td>

                                <td>
                                    {{ project.responsible }}
                                </td>

                                <td>
                                    <div class="progress" style="height: 6px; width: 120px;">
                                        <div class="progress-bar"
                                            style="width: {{ project.progress }}%">
                                        </div>
                                    </div>

                                    <small class="text-muted">
                                        %{{ project.progress }}
                                    </small>
                                </td>

                                <td>
                                    <span class="badge bg-soft-info text-info">
                                        {{ project.status }}
                                    </span>
                                </td>

                                <td class="text-end pe-4">
                                    <a href="{{ path('app_project_edit', {'id': project.id}) }}"
                                        class="btn btn-sm btn-outline-primary">
                                        <i class="fas fa-edit"></i>
                                        Edit
                                    </a>

                                </td>

                            </tr>

                        {% else %}

                            <tr>
                                <td colspan="5" class="text-center p-4">
                                    No projects found
                                </td>
                            </tr>

                        {% endfor %}

                        </tbody>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
{% endblock %}
