{% extends 'base.html.twig' %}

{% block title %}Log in!{% endblock %}

{% block body %}
<div class="row justify-content-center mt-5">
    <div class="col-lg-5">
        <div class="card shadow-lg border-0">
            {# Edit User sayfasındaki aynı mavi gradient header #}
            <div class="card-header bg-gradient text-white" style="background: linear-gradient(90deg,#0d6efd,#4facfe);">
                <h4 class="mb-0"><i class="bi bi-shield-lock-fill"></i> Please sign in</h4>
            </div>

            <div class="card-body p-4">
                <form method="post">
                    {% if error %}
                        <div class="alert alert-danger shadow-sm border-0">
                            <i class="bi bi-exclamation-circle-fill"></i> {{ error.messageKey|trans(error.messageData, 'security') }}
                        </div>
                    {% endif %}

                    {% if app.user %}
                        <div class="alert alert-info border-0 shadow-sm mb-3">
                            You are logged in as <strong>{{ app.user.userIdentifier }}</strong>, 
                            <a href="{{ logout_path() }}" class="alert-link text-decoration-none">Logout</a>
                        </div>
                    {% endif %}

                    {# Email Alanı #}
                    <div class="mb-3">
                        <label for="inputEmail" class="form-label">Email</label>
                        <input type="email" value="{{ last_username }}" name="email" id="inputEmail" class="form-control" autocomplete="email" required autofocus placeholder="Enter your email">
                    </div>

                    {# Şifre Alanı #}
                    <div class="mb-3">
                        <label for="inputPassword" class="form-label">Password</label>
                        <input type="password" name="password" id="inputPassword" class="form-control" autocomplete="current-password" required placeholder="Enter your password">
                    </div>

                    <input type="hidden" name="_csrf_token" data-controller="csrf-protection" value="{{ csrf_token('authenticate') }}">

                    {# Beni Hatırla ve Buton Satırı #}
                    <div class="row align-items-center mt-4">
                        <div class="col-6">
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" name="_remember_me" id="rememberMe">
                                <label class="form-check-label" for="rememberMe">
                                    Remember me
                                </label>
                            </div>
                        </div>
                        <div class="col-6 text-end">
                            <button class="btn btn-primary px-4 shadow-sm" type="submit">
                                Sign in <i class="bi bi-box-arrow-in-right ms-1"></i>
                            </button>
                        </div>
                    </div>
                </form>
            </div>
        </div>

        {# Alt tarafa Kayıt Ol yönlendirmesi eklemek istersen #}
        <div class="text-center mt-3">
            <p class="text-muted small">Don't have an account? <a href="{{ path('app_register') }}" class="text-primary text-decoration-none">Sign up</a></p>
        </div>
    </div>
</div>
{% endblock %}
