{% extends 'base.html.twig' %}

{% block body %}

<div class="row justify-content-center mt-4">

    <div class="col-lg-6">

        <div class="card shadow-lg border-0">

            <div class="card-header bg-gradient text-white" style="background: linear-gradient(90deg,#0d6efd,#4facfe);">
                <h4 class="mb-0"><i class="bi bi-person-fill-gear"></i> Edit User</h4>
            </div>

            <div class="card-body p-4">
                {{ include('user/_form.html.twig', {'button_label': 'Update'}) }}
            </div>

        </div>

        <div class="mt-3 mb-5 d-flex gap-2">

            <a href="{{ path('app_user_index') }}" class="btn btn-secondary">
                <i class="bi bi-arrow-left"></i> Back
            </a>

        </div>

    </div>

</div>

{% endblock %}

