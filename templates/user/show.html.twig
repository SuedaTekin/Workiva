{% extends 'base.html.twig' %}


{% block body %}

<div class="row justify-content-center mt-4">

    <div class="col-lg-6">

        <div class="card shadow-lg border-0">

            <div class="card-header bg-gradient text-white" style="background: linear-gradient(90deg,#0d6efd,#4facfe);">
                <h4 class="mb-0"><i class="bi bi-person-badge-fill"></i> User Details</h4>
            </div>

            <div class="card-body">

                <table class="table table-borderless">
                    <tbody>
                        <tr>
                            <th>Name</th>
                            <td>{{ user.name }}</td>
                        </tr>
                        <tr>
                            <th>Username</th>
                            <td>{{ user.surname }}</td>
                        </tr>
                        <tr>
                            <th>Email</th>
                            <td>{{ user.email }}</td>
                        </tr>
                        <tr>
                            <th>Age</th>
                            <td>{{ user.age }}</td>
                        </tr>
                        <tr>
                            <th>Gender</th>
                            <td>{{ user.gender }}</td>
                        </tr>
                    </tbody>
                </table>

            </div>

            <div class="card-footer d-flex justify-content-between align-items-center">

    <a href="{{ path('app_user_index') }}" class="btn btn-secondary">
        <i class="bi bi-arrow-left"></i> Back
    </a>

    <div class="d-flex align-items-center" style="gap:10px;">
        <a href="{{ path('app_user_edit', {'id': user.id}) }}" class="btn btn-warning">
            <i class="bi bi-pencil-fill"></i> Edit
        </a>

        <div>
            {{ include('user/_delete_form.html.twig') }}
        </div>

        </div>

    </div>

</div>

{% endblock %}